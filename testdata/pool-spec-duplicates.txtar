tail-logs
create-pool

exec restic-rados-server --pool $RESTIC_RADOS_SERVER_POOL --pool $RESTIC_RADOS_SERVER_POOL --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true' --output /dev/null
stdout '200'

kill server

exec restic-rados-server --pool $RESTIC_RADOS_SERVER_POOL':*;'$RESTIC_RADOS_SERVER_POOL':*' --listen $WORK/restic2.sock &server2&
wait4socket $WORK/restic2.sock

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic2.sock 'http://localhost/config' --output /dev/null
stdout '404'

kill server2

exec restic-rados-server --pool $RESTIC_RADOS_SERVER_POOL --pool $RESTIC_RADOS_SERVER_POOL':data' --listen $WORK/restic3.sock &server3&
wait4socket $WORK/restic3.sock

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic3.sock 'http://localhost/data/' --output /dev/null
stdout '200'

kill server3

exec restic-rados-server --pool $RESTIC_RADOS_SERVER_POOL':data' --pool $RESTIC_RADOS_SERVER_POOL --listen $WORK/restic4.sock &server4&
wait4socket $WORK/restic4.sock

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic4.sock 'http://localhost/data/' --output /dev/null
stdout '200'

kill server4

! exec restic-rados-server --pool $RESTIC_RADOS_SERVER_POOL':datta' --pool $RESTIC_RADOS_SERVER_POOL':*' --listen $WORK/restic5.sock
stderr 'unknown blob type "datta"'

! exec restic-rados-server --pool $RESTIC_RADOS_SERVER_POOL':*' --pool $RESTIC_RADOS_SERVER_POOL':datta' --listen $WORK/restic6.sock
stderr 'unknown blob type "datta"'
