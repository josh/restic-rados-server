tail-logs
create-pool

exec restic-rados-server --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock 'http://localhost/data/' --output /dev/null
stdout '200'

exec ceph osd pool rm $RESTIC_RADOS_SERVER_POOL $RESTIC_RADOS_SERVER_POOL --yes-i-really-really-mean-it

exec bash wait-pool-gone.sh
cmp stdout expected-status.txt

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock 'http://localhost/config' --output /dev/null
stdout '503'

kill server

-- wait-pool-gone.sh --
set -o errexit

for i in $(seq 1 30); do
	code=$(curl --silent --write-out '%{http_code}' --unix-socket "$WORK/restic.sock" 'http://localhost/data/' --output /dev/null)
	if [ "$code" != "200" ]; then
		printf '%s\n' "$code"
		exit 0
	fi
	sleep 1
done
printf 'pool deletion never became visible'
exit 1
-- expected-status.txt --
503