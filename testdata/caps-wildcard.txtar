tail-logs
create-pool alpha
create-pool beta

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json --listen $WORK/restic.sock?trusted-caps-header=X-Restic-Capabilities &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"rw"}' --unix-socket $WORK/restic.sock --request POST 'http://localhost/db/?create=true' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"ra"}' --unix-socket $WORK/restic.sock --request POST --data-binary @blob-data 'http://localhost/db/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"ra"}' --unix-socket $WORK/restic.sock --request DELETE 'http://localhost/db/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '403'

kill server

-- config.json.tmpl --
{
    "repos": {
        "default": {"pools": {"$CEPH_POOL_ALPHA": ["*"]}},
        "db": {"pools": {"$CEPH_POOL_BETA": ["*"]}}
    }
}
-- blob-data --
test blob content
