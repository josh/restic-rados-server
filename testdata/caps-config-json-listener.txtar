tail-logs
create-pool

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"rw"}' --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"r"}' --unix-socket $WORK/restic.sock --request POST --data-binary @blob-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '403'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request GET 'http://localhost/config' --output /dev/null
stdout '403'

kill server

-- config.json.tmpl --
{
    "listen": ["$WORK/restic.sock?trusted-caps-header=X-Restic-Capabilities"]
}
-- blob-data --
test blob content
