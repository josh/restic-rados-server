tail-logs
create-pool

exec restic-rados-server --listen $WORK/restic.sock?trusted-ts-caps=github.com/josh/restic-rados-server &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"rw"}]}' --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"ra"}]}' --unix-socket $WORK/restic.sock --request POST --data-binary @blob-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"ra"}]}' --unix-socket $WORK/restic.sock --request DELETE 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '403'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"ra"}]}' --unix-socket $WORK/restic.sock --request POST --data-binary @lock-data 'http://localhost/locks/5ad8ba0b31f9699fed5f80f6ef585e09429c1c1534a83a655fb2b3934f56ca45' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"ra"}]}' --unix-socket $WORK/restic.sock --request DELETE 'http://localhost/locks/5ad8ba0b31f9699fed5f80f6ef585e09429c1c1534a83a655fb2b3934f56ca45' --output /dev/null
stdout '200'

kill server

-- blob-data --
test blob content
-- lock-data --
{"time":"2025-01-01T00:00:00Z","hostname":"test"}
