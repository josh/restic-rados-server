tail-logs
create-pool

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json &server&
wait4socket $WORK/file.sock

exec curl --silent --unix-socket $WORK/file.sock --request POST 'http://localhost/?create=true'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/file.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @blob-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

exec curl --silent --unix-socket $WORK/file.sock 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output downloaded
cmp downloaded blob-data

kill server

-- config.json.tmpl --
{
    "verbose": true,
    "listen": ["unix://$WORK/file.sock"],
    "shutdown_timeout": "30s",
    "max_idle_time": "0s",
    "read_buffer_size": 65536,
    "write_buffer_size": 65536,
    "repos": {
        "default": {
            "pools": {"$RESTIC_RADOS_SERVER_POOL": ["*"]}
        }
    }
}
-- blob-data --
test blob content
