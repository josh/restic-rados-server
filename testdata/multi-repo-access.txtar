tail-logs
create-pool alpha
create-pool beta

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true'
exec curl --silent --unix-socket $WORK/restic.sock --request POST --data-binary @blob-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request DELETE 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '403'

exec curl --silent --unix-socket $WORK/restic.sock --request POST 'http://localhost/rw/?create=true'
exec curl --silent --unix-socket $WORK/restic.sock --request POST --data-binary @blob-data 'http://localhost/rw/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request DELETE 'http://localhost/rw/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

kill server

-- config.json.tmpl --
{
    "repos": {
        "default": {"pools": {"$CEPH_POOL_ALPHA": ["*"]}, "access": "ra"},
        "rw": {"pools": {"$CEPH_POOL_BETA": ["*"]}}
    }
}
-- blob-data --
test blob content
