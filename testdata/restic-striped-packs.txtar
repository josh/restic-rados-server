tail-logs
create-pool

exec restic init --option rclone.program=restic-rados-server --option rclone.args='--max-object-size 4194304' --repo rclone: --password-file password.txt

mkdir data
bin-file rand data/big.bin 25165824

exec restic backup data --option rclone.program=restic-rados-server --option rclone.args='--max-object-size 4194304' --repo rclone: --password-file password.txt

exec rados --pool $RESTIC_RADOS_SERVER_POOL ls
stdout '^data/[0-9a-f]{64}\.0000000000000000$'

exec restic check --option rclone.program=restic-rados-server --option rclone.args='--max-object-size 4194304' --repo rclone: --password-file password.txt

exec restic restore latest --target $WORK/restored --option rclone.program=restic-rados-server --option rclone.args='--max-object-size 4194304' --repo rclone: --password-file password.txt

bin-cmp $WORK/restored/data/big.bin data/big.bin

-- password.txt --
secret
