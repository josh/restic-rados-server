tail-logs
create-pool filepool
create-pool clipool

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json --pool $CEPH_POOL_CLIPOOL --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data http://localhost/config --output /dev/null
stdout '200'

exec rados --pool $CEPH_POOL_CLIPOOL ls
stdout '^config$'

exec rados --pool $CEPH_POOL_FILEPOOL ls
! stdout '.'

kill server

-- config.json.tmpl --
{
    "repos": {
        "default": {
            "blob_pools": {
                "config": {"pool": "$CEPH_POOL_FILEPOOL"},
                "keys": {"pool": "$CEPH_POOL_FILEPOOL"},
                "locks": {"pool": "$CEPH_POOL_FILEPOOL"},
                "snapshots": {"pool": "$CEPH_POOL_FILEPOOL"},
                "data": {"pool": "$CEPH_POOL_FILEPOOL"},
                "index": {"pool": "$CEPH_POOL_FILEPOOL"}
            }
        }
    }
}
-- config-data --
{"version":2,"id":"test","chunker_polynomial":"25b468838dcb75ea"}
