tail-logs
create-pool

exec restic-rados-server --config cap.json --listen 127.0.0.1:$PORT --log-file $WORK/loopback.log &lbserver&
wait4socket 127.0.0.1:$PORT
kill lbserver
! wait4socket 127.0.0.1:$PORT

! grep 'non-loopback' $WORK/loopback.log

exec restic-rados-server --config cap.json --listen 0.0.0.0:$PORT --log-file $WORK/any.log &anyserver&
wait4socket 127.0.0.1:$PORT
kill anyserver

grep 'non-loopback' $WORK/any.log

-- cap.json --
{
    "tailscale_capability": "github.com/josh/restic-rados-server"
}
