tail-logs
create-pool

exec restic-rados-server --listen $WORK/plain.sock --listen $WORK/caps.sock?trusted-caps-header=X-Restic-Capabilities &server&
wait4socket $WORK/plain.sock
wait4socket $WORK/caps.sock

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/plain.sock --request POST 'http://localhost/?create=true' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"r"}' --unix-socket $WORK/plain.sock --request POST --data-binary @blob-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"r"}' --unix-socket $WORK/plain.sock --request DELETE 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"r"}' --unix-socket $WORK/caps.sock --request POST --data-binary @blob-data 'http://localhost/data/bcd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075b' --output /dev/null
stdout '403'

kill server

-- blob-data --
test blob content
