tail-logs
create-pool alpha
create-pool beta
create-pool gamma

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --unix-socket $WORK/restic.sock --request POST 'http://localhost/backup/?create=true'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data 'http://localhost/backup/config' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @data-blob 'http://localhost/backup/data/66a575ca1f5a22ffafae6c796191c6496b49f149a63b465268023e7027364d96' --output /dev/null
stdout '200'

exec rados --pool $CEPH_POOL_BETA ls
stdout '^data/66a575ca1f5a22ffafae6c796191c6496b49f149a63b465268023e7027364d96$'
! stdout '^config$'

exec rados --pool $CEPH_POOL_GAMMA ls
stdout '^config$'
! stdout '^data/'

exec rados --pool $CEPH_POOL_ALPHA ls
! stdout '.'

kill server

-- config.json.tmpl --
{
    "repos": {
        "default": {
            "pools": {"$CEPH_POOL_ALPHA": ["*"]}
        },
        "backup": {
            "pools": {
                "$CEPH_POOL_BETA": ["data", "snapshots"],
                "$CEPH_POOL_GAMMA": ["*"]
            }
        }
    }
}
-- config-data --
{"version":2,"id":"test","chunker_polynomial":"25b468838dcb75ea"}
-- data-blob --
fresh blob content
