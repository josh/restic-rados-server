! exec restic-rados-server --pool=foo/:keys
stderr 'invalid pool'

! exec restic-rados-server --pool=foo//foo:data
stderr 'invalid pool'

! exec restic-rados-server --pool=foo:data,*
stderr 'cannot be mixed with explicit types'

! exec restic-rados-server --pool=/ns:keys
stderr 'empty pool name in specification'

! exec restic-rados-server --pool=foo:
stderr 'invalid pool'

! exec restic-rados-server --pool=new-pool//:data
stderr 'empty lower pool name in specification'

! exec restic-rados-server --pool=pool1//pool2//pool3
stderr 'namespace cannot start with ./. in specification'

! exec restic-rados-server --pool=foo/a/b:data
stderr 'namespace cannot contain ./. in specification'

! exec restic-rados-server --config slash-namespace.json
stderr 'namespace cannot contain ./. in specification'

! exec restic-rados-server --config lower-slash-namespace.json
stderr 'namespace cannot contain ./. in specification'

! exec restic-rados-server --config identical-layers.json
stderr 'lower layer must differ from upper layer'

! exec restic-rados-server --config empty-pool-name.json
stderr 'empty pool name in specification'

! exec restic-rados-server --config empty-lower-pool.json
stderr 'empty lower pool name in specification'

-- slash-namespace.json --
{
    "repos": {
        "default": {
            "pools": {"foo/a/b": ["*"]}
        }
    }
}
-- lower-slash-namespace.json --
{
    "repos": {
        "default": {
            "pools": {"foo//bar/a/b": ["*"]}
        }
    }
}
-- identical-layers.json --
{
    "repos": {
        "default": {
            "pools": {"foo//foo": ["data"]}
        }
    }
}
-- empty-pool-name.json --
{
    "repos": {
        "default": {
            "pools": {"": ["data"]}
        }
    }
}
-- empty-lower-pool.json --
{
    "repos": {
        "default": {
            "pools": {"new-pool//": ["*"]}
        }
    }
}
