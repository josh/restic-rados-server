tail-logs
create-pool new
create-pool old
create-pool meta

exec restic-rados-server --pool $CEPH_POOL_OLD --listen $WORK/seed.sock &seedserver&
wait4socket $WORK/seed.sock

exec curl --silent --unix-socket $WORK/seed.sock --request POST 'http://localhost/?create=true'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/seed.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @old-data 'http://localhost/data/8ddad7f94d83b3cfce2b5ced86114c241fd5ae1121bfcf06218982ae9e635cb3' --output /dev/null
stdout '200'

kill seedserver

env RESTIC_RADOS_SERVER_POOL=$CEPH_POOL_NEW'//'$CEPH_POOL_OLD':data;'$CEPH_POOL_META':*'

exec restic-rados-server --listen $WORK/overlay.sock &overlayserver&
wait4socket $WORK/overlay.sock

exec curl --silent --unix-socket $WORK/overlay.sock --request POST 'http://localhost/?create=true'

exec curl --silent --unix-socket $WORK/overlay.sock 'http://localhost/data/8ddad7f94d83b3cfce2b5ced86114c241fd5ae1121bfcf06218982ae9e635cb3' --output downloaded-old
cmp downloaded-old old-data

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/overlay.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data http://localhost/config --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/overlay.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @new-data 'http://localhost/data/66a575ca1f5a22ffafae6c796191c6496b49f149a63b465268023e7027364d96' --output /dev/null
stdout '200'

exec rados --pool $CEPH_POOL_NEW ls
stdout '^data/66a575ca1f5a22ffafae6c796191c6496b49f149a63b465268023e7027364d96$'
! stdout '^config$'

exec rados --pool $CEPH_POOL_META ls
stdout '^config$'

kill overlayserver

-- old-data --
legacy blob content
-- new-data --
fresh blob content
-- config-data --
{"version":2,"id":"test","chunker_polynomial":"25b468838dcb75ea"}
