tail-logs
create-pool

exec restic-rados-server --listen $WORK/restic.sock?trusted-ts-caps=github.com/josh/restic-rados-server &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"rw"}]}' --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"rw","note":"=?utf-8?B?Ig==?="}]}' --unix-socket $WORK/restic.sock --request POST --data-binary @blob-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

kill server

-- blob-data --
test blob content
