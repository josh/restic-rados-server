tail-logs
create-pool shared

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data http://localhost/config --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @key-data 'http://localhost/keys/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

exec rados --pool $CEPH_POOL_SHARED --namespace ns ls
stdout '^p1/config$'
stdout '^p1/keys/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a$'
! stdout '^config$'
! stdout '^keys/'

exec rados --pool $CEPH_POOL_SHARED ls
! stdout 'config'
! stdout 'keys/'

exec curl --silent --unix-socket $WORK/restic.sock http://localhost/config --output downloaded-config
cmp downloaded-config config-data

exec curl --silent --unix-socket $WORK/restic.sock 'http://localhost/keys/'
stdout 'abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request DELETE 'http://localhost/keys/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

exec rados --pool $CEPH_POOL_SHARED --namespace ns ls
! stdout 'keys/'

kill server

-- config.json.tmpl --
{
    "repos": {
        "default": {
            "blob_pools": {
                "config": {"pool": "$CEPH_POOL_SHARED", "namespace": "ns", "prefix": "p1/"},
                "keys": {"pool": "$CEPH_POOL_SHARED", "namespace": "ns", "prefix": "p1/"},
                "locks": {"pool": "$CEPH_POOL_SHARED", "namespace": "ns", "prefix": "p1/"},
                "snapshots": {"pool": "$CEPH_POOL_SHARED", "namespace": "ns", "prefix": "p1/"},
                "data": {"pool": "$CEPH_POOL_SHARED", "namespace": "ns", "prefix": "p1/"},
                "index": {"pool": "$CEPH_POOL_SHARED", "namespace": "ns", "prefix": "p1/"}
            }
        }
    }
}
-- config-data --
{"version":2,"id":"test","chunker_polynomial":"25b468838dcb75ea"}
-- key-data --
test blob content
