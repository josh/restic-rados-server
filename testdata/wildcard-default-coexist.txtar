tail-logs
create-pool alpha
create-pool beta

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data http://localhost/config --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @blob-z 'http://localhost/data/f2ca1bb6c7e907d06dafe4687e579fce76b37e4e93b7605022da52e6ccc26fd2' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock 'http://localhost/keys/' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock 'http://localhost/healthz' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock 'http://localhost/readyz' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data http://localhost/somerepo/config --output /dev/null
stdout '200'

exec rados --pool $CEPH_POOL_ALPHA ls
stdout '^config$'
stdout '^data/f2ca1bb6c7e907d06dafe4687e579fce76b37e4e93b7605022da52e6ccc26fd2$'

exec rados --pool $CEPH_POOL_BETA --namespace somerepo ls
stdout '^config$'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock 'http://localhost/default/config' --output /dev/null
stdout '404'

kill server

-- config.json.tmpl --
{
    "repos": {
        "default": {
            "pools": {"$CEPH_POOL_ALPHA": ["*"]}
        },
        "*": {
            "pools": {"$CEPH_POOL_BETA/{repo}": ["*"]}
        }
    }
}
-- config-data --
{"version":2,"id":"test","chunker_polynomial":"25b468838dcb75ea"}
-- blob-z --
test
