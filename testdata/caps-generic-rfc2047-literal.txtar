tail-logs
create-pool

exec restic-rados-server --listen $WORK/restic.sock?trusted-caps-header=X-Restic-Capabilities &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"rw"}' --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: =?utf-8?B?eyIqIjoicncifQ==?=' --unix-socket $WORK/restic.sock --request POST --data-binary @blob-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '403'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: =?utf-8?B?eyIqIjoicncifQ==?=' --unix-socket $WORK/restic.sock --request GET 'http://localhost/config' --output /dev/null
stdout '403'

exec curl --silent --write-out '%{http_code}' --header 'X-Restic-Capabilities: {"*":"rw"}' --unix-socket $WORK/restic.sock --request POST --data-binary @blob-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

kill server

-- blob-data --
test blob content
