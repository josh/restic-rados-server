tail-logs
create-pool alpha
create-pool beta
create-pool gamma

envsubst config.json.tmpl config.json

exec restic-rados-server --config config.json --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data http://localhost/backup/config --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data http://localhost/backups-x/config --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @config-data http://localhost/zzz/config --output /dev/null
stdout '200'

exec rados --pool $CEPH_POOL_ALPHA ls
stdout '^config$'

exec rados --pool $CEPH_POOL_BETA --namespace x ls
stdout '^config$'

exec rados --pool $CEPH_POOL_GAMMA --namespace zzz ls
stdout '^config$'

exec rados --pool $CEPH_POOL_GAMMA --namespace backup ls
! stdout 'config'

exec rados --pool $CEPH_POOL_GAMMA --namespace backups-x ls
! stdout 'config'

kill server

-- config.json.tmpl --
{
    "repos": {
        "backup": {
            "pools": {"$CEPH_POOL_ALPHA": ["*"]}
        },
        "backups-*": {
            "pools": {"$CEPH_POOL_BETA/{repo_match}": ["*"]}
        },
        "*": {
            "pools": {"$CEPH_POOL_GAMMA/{repo}": ["*"]}
        }
    }
}
-- config-data --
{"version":2,"id":"test","chunker_polynomial":"25b468838dcb75ea"}
