tail-logs
create-pool

exec restic-rados-server --max-object-size 4194304 --listen $WORK/small.sock &smallserver&
wait4socket $WORK/small.sock

exec curl --silent --unix-socket $WORK/small.sock --request POST 'http://localhost/?create=true'

bin-file rand blob 8388608
sha256 blob HASH

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/small.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @blob 'http://localhost/data/'$HASH --output /dev/null
stdout '200'

exec rados --pool $RESTIC_RADOS_SERVER_POOL ls
stdout '^data/'$HASH'\.0000000000000000$'
stdout '^data/'$HASH'\.0000000000000001$'

kill smallserver

exec restic-rados-server --max-object-size 16777216 --listen $WORK/big.sock &bigserver&
wait4socket $WORK/big.sock

exec curl --silent --write-out '%{http_code}' --unix-socket $WORK/big.sock --request DELETE 'http://localhost/data/'$HASH --output /dev/null
stdout '200'

rados-object-count data/
cmp stdout zero.txt

! grep 'orphaned=true' $RESTIC_RADOS_SERVER_LOG_FILE

kill bigserver

-- zero.txt --
0
