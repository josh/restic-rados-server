! exec restic-rados-server --config slash-name.json
stderr 'invalid repo name'

! exec restic-rados-server --config space-name.json
stderr 'invalid repo name'

! exec restic-rados-server --config invalid-access.json
stderr 'invalid access "RW" \(must be r, ra, or rw\)'

! exec restic-rados-server --config dot-name.json
stderr 'invalid repo name "\." \(must not be "\." or "\.\."\)'

! exec restic-rados-server --config dotdot-name.json
stderr 'invalid repo name "\.\." \(must not be "\." or "\.\."\)'

! exec restic-rados-server --config empty-name.json
stderr 'invalid repo name'

! exec restic-rados-server --config brace-name.json
stderr 'invalid repo name'

! exec restic-rados-server --config tab-name.json
stderr 'invalid repo name'

-- slash-name.json --
{
    "repos": {
        "bad/name": {"pools": {"pool": ["*"]}}
    }
}
-- space-name.json --
{
    "repos": {
        "bad name": {"pools": {"pool": ["*"]}}
    }
}
-- invalid-access.json --
{
    "repos": {
        "default": {"access": "RW", "pools": {"pool": ["*"]}}
    }
}
-- dot-name.json --
{
    "repos": {
        ".": {"pools": {"pool": ["*"]}}
    }
}
-- dotdot-name.json --
{
    "repos": {
        "..": {"pools": {"pool": ["*"]}}
    }
}
-- empty-name.json --
{
    "repos": {
        "": {"pools": {"pool": ["*"]}}
    }
}
-- brace-name.json --
{
    "repos": {
        "{x}": {"pools": {"pool": ["*"]}}
    }
}
-- tab-name.json --
{
    "repos": {
        "repo\ttab": {"pools": {"pool": ["*"]}}
    }
}
