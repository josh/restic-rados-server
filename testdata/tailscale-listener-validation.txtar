! exec restic-rados-server --listen tailscale+svc:-restic --pool my-pool
stderr '"-restic" is not a valid DNS label'

! exec restic-rados-server --listen tailscale+svc://web.server --pool my-pool
stderr '"web.server" is not a valid DNS label'

! exec restic-rados-server --listen tailscale+svc: --pool my-pool
stderr 'must not be empty after the .svc:. prefix'

! exec restic-rados-server --listen svc:restic --pool my-pool
stderr 'use tailscale\+svc:restic to serve a Tailscale Service'

! exec restic-rados-server --config multi-upstream.json
stderr 'tailscale upstream_socket requires exactly one tailscale\+svc listener, got 2'

! exec restic-rados-server --listen tailscale+svc:restic --listen tailscale+svc:RESTIC --pool my-pool
stderr 'duplicate tailscale\+svc listener for "svc:restic"'

! exec restic-rados-server --listen tailscale+svc:restic --max-idle-time 30s --pool my-pool
stderr 'max-idle-time is not supported with tailscale\+svc listeners'

! exec restic-rados-server --config bad-port.json
stderr 'tailscale port must be between 1 and 65535, got 70000'

! exec restic-rados-server --config negative-port.json
stderr 'tailscale port must be between 1 and 65535, got -1'

! exec restic-rados-server --config unknown-field.json
stderr 'unknown field "authkey"'

-- multi-upstream.json --
{
    "listen": ["tailscale+svc:one", "tailscale+svc:two"],
    "tailscale": {"upstream_socket": "/run/restic.sock"},
    "repos": {
        "default": {"pools": {"my-pool": ["*"]}}
    }
}
-- bad-port.json --
{
    "listen": ["tailscale+svc:restic"],
    "tailscale": {"port": 70000},
    "repos": {
        "default": {"pools": {"my-pool": ["*"]}}
    }
}
-- negative-port.json --
{
    "listen": ["tailscale+svc:restic"],
    "tailscale": {"port": -1},
    "repos": {
        "default": {"pools": {"my-pool": ["*"]}}
    }
}
-- unknown-field.json --
{
    "listen": ["tailscale+svc:restic"],
    "tailscale": {"authkey": "tskey-secret"},
    "repos": {
        "default": {"pools": {"my-pool": ["*"]}}
    }
}
