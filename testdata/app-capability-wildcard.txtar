tail-logs
create-pool

exec restic-rados-server --config config.json --listen $WORK/restic.sock &server&
wait4socket $WORK/restic.sock

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"rw"}]}' --unix-socket $WORK/restic.sock --request POST 'http://localhost/?create=true' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"rw"}]}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @blob-data 'http://localhost/data/5ea275e382108894dc0f0356c00541e55a31cf54bc372ee0418ea630bcefd56e' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"rw"}]}' --unix-socket $WORK/restic.sock 'http://localhost/data/5ea275e382108894dc0f0356c00541e55a31cf54bc372ee0418ea630bcefd56e' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"other":"rw"}]}' --unix-socket $WORK/restic.sock 'http://localhost/data/5ea275e382108894dc0f0356c00541e55a31cf54bc372ee0418ea630bcefd56e' --output /dev/null
stdout '403'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"r"},{"default":"ra"}]}' --unix-socket $WORK/restic.sock --request POST --header 'Content-Type: application/octet-stream' --data-binary @merge-data 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '200'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"r"},{"default":"ra"}]}' --unix-socket $WORK/restic.sock --request DELETE 'http://localhost/data/abd9a2bf47af3416b041796843b9f9a7a5e987356da7ccfc750816219f0a075a' --output /dev/null
stdout '403'

exec curl --silent --write-out '%{http_code}' --header 'Tailscale-App-Capabilities: {"github.com/josh/restic-rados-server":[{"*":"rw"}]}' --unix-socket $WORK/restic.sock --request DELETE 'http://localhost/data/5ea275e382108894dc0f0356c00541e55a31cf54bc372ee0418ea630bcefd56e' --output /dev/null
stdout '200'

kill server

-- config.json --
{
    "tailscale_capability": "github.com/josh/restic-rados-server"
}
-- blob-data --
wildcard blob content
-- merge-data --
test blob content
